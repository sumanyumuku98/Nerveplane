{
  "name": "nerveplane",
  "version": "0.1.0",
  "description": "Local-first, MCP-compatible coordination plane for autonomous coding agents",
  "homepage": "https://sumanyumuku98.github.io/Nerveplane/",
  "repository": { "type": "git", "url": "https://github.com/sumanyumuku98/Nerveplane.git" },
  "license": "MIT",
  "type": "module",
  "bin": {
    "nerveplane": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "daemon": "bun run src/index.ts daemon",
    "dev": "bun --watch run src/index.ts daemon",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/storage/migrate.ts",
    "build": "bun build --compile --target=bun src/index.ts --outfile dist/nerveplane",
    "build:dashboard": "cd dashboard && vite build",
    "dev:dashboard": "cd dashboard && vite",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@graphql-inspector/core": "7.1.3",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "drizzle-orm": "^0.44.0",
    "graphql": "16.14.1",
    "hono": "4.12.23",
    "simple-git": "^3.27.0",
    "yaml": "2.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@types/bun": "^1.2.0",
    "drizzle-kit": "^0.31.0",
    "svelte": "5.56.1",
    "typescript": "^5.7.0",
    "vite": "8.0.16",
    "vitepress": "1.6.4",
    "vue": "3.5.35"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
